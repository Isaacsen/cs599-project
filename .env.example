# Copy this file to .env and fill values locally.
# Do not commit real API keys.

LLM_PROVIDER=dashscope
# DashScope is the default provider. Prefer DASHSCOPE_API_KEY for DashScope.
DASHSCOPE_API_KEY=
# DeepSeek is also supported. Use LLM_PROVIDER=deepseek to enable.
DEEPSEEK_API_KEY=
# LLM_API_KEY is kept as a generic fallback for other providers.
LLM_API_KEY=
LLM_MODEL=glm-5.2
TESTGUARD_TIMEOUT_SECONDS=30
